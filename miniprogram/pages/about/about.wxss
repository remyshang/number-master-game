.container {
  padding: 40rpx 20rpx;
}

.title {
  font-size: 60rpx;
  font-weight: bold;
  color: #4a5568;
  text-align: center;
  margin-bottom: 20rpx;
}

.about-content {
  background: white;
  border-radius: 30rpx;
  padding: 60rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 15rpx 35rpx rgba(0, 0, 0, 0.1);
}

.about-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #4a5568;
  margin-bottom: 30rpx;
}

.about-text {
  font-size: 32rpx;
  color: #718096;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.about-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
  margin: 60rpx 0;
}

.about-stat {
  text-align: center;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
}

.about-stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
}

.about-stat-label {
  font-size: 24rpx;
  color: #718096;
  margin-top: 10rpx;
}

.share-section {
  margin-bottom: 30rpx;
}

.share-btn {
  background: linear-gradient(135deg, #48bb78 0%, #38a169 100%);
  color: white;
  padding: 40rpx 80rpx;
  border: none;
  border-radius: 25rpx;
  font-size: 32rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
}

.share-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 20rpx 40rpx rgba(72, 187, 120, 0.3);
}

.support-section {
  margin-bottom: 40rpx;
}

.support-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 40rpx 80rpx;
  border: none;
  border-radius: 25rpx;
  font-size: 32rpx;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  width: 100%;
}

.support-btn:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 20rpx 40rpx rgba(102, 126, 234, 0.3);
}